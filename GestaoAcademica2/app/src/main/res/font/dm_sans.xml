<?xml version="1.0" encoding="utf-8"?>
<!-- Declara os dois namespaces: android: (parser do framework, usado pelo tema)
     e app: (loader do AppCompat). Sem o android:, a fonte padrão do tema cai no Roboto. -->
<font-family
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <font
        android:fontStyle="normal" android:fontWeight="400" android:font="@font/dm_sans_regular"
        app:fontStyle="normal" app:fontWeight="400" app:font="@font/dm_sans_regular" />
    <font
        android:fontStyle="normal" android:fontWeight="500" android:font="@font/dm_sans_medium"
        app:fontStyle="normal" app:fontWeight="500" app:font="@font/dm_sans_medium" />
    <font
        android:fontStyle="normal" android:fontWeight="600" android:font="@font/dm_sans_semibold"
        app:fontStyle="normal" app:fontWeight="600" app:font="@font/dm_sans_semibold" />
    <font
        android:fontStyle="normal" android:fontWeight="700" android:font="@font/dm_sans_bold"
        app:fontStyle="normal" app:fontWeight="700" app:font="@font/dm_sans_bold" />
</font-family>
